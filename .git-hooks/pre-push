#!/bin/sh
# Managed pre-push hook — gate (+ deploy where applicable) logic lives in
# scripts/prepush.sh. (core.hooksPath=.git-hooks is set manually — see the
# `git config core.hooksPath .git-hooks` line in AGENTS.md; no npm here.)
# git passes <remote-name> <remote-url> as args and the pushed refs on stdin;
# exec preserves both for scripts/prepush.sh.
exec bash "$(git rev-parse --show-toplevel)/scripts/prepush.sh" "$@"
