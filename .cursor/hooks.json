{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "bash .agents/hooks/block-git-no-verify.sh",
        "failClosed": true,
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "command": "bash .agents/hooks/block-fleet-edits.sh",
        "failClosed": false,
        "timeout": 5,
        "matcher": "Write|Delete"
      }
    ]
  }
}
