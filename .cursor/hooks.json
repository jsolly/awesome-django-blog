{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "bash .agents/hooks/block-git-no-verify.sh",
        "failClosed": true,
        "timeout": 5
      }
    ],
    "sessionStart": [
      {
        "command": "bash .agents/hooks/check-fleet-subtree-stale.sh",
        "timeout": 15
      }
    ]
  }
}
